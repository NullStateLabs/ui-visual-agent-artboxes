# URL of the app to test (default: http://localhost:3000)
# Single-app project: set BASE_URL and use relative paths in your config (e.g. url: "/collections")
BASE_URL=https://your-app.com

# Monorepo with multiple apps: set one URL per app and use absolute paths in your config.
# Leave unset if your project has only one app.
# WEB_URL=https://artboxes.io
# ARTIST_URL=https://artist.artboxes.io
# PRELAUNCH_URL=https://pre.artboxes.io

# Anthropic API key for Claude Vision analysis
ANTHROPIC_API_KEY=sk-ant-...

# Postgres connection string for bug ticket storage
DATABASE_URL=postgresql://user:pass@localhost:5432/mydb

# GitHub PAT with repo scope — used by fix agent to open PRs
UI_FIX_GITHUB_TOKEN=ghp_...

# Target repo for PRs (fix agent)
# Note: don't use GITHUB_ prefix — GitHub reserves that namespace
REPO_OWNER=your-org
REPO_NAME=your-repo
REPO_BRANCH=main

# Set to "true" to skip real LLM call (returns hardcoded fail for pipeline testing)
MOCK_LLM=false

# Shell command to verify the build before pushing fixed code.
# Runs inside a shallow clone of the target repo.
# If the build fails, the push is aborted entirely — nothing reaches GitHub.
# Leave unset to skip the build check.
# BUILD_COMMAND=pnpm install --frozen-lockfile && pnpm build

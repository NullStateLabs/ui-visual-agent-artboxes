# URL of the app to test (default: http://localhost:3000)
BASE_URL=https://your-app.com

# Anthropic API key for Claude Vision analysis
ANTHROPIC_API_KEY=sk-ant-...

# Postgres connection string for bug ticket storage
DATABASE_URL=postgresql://user:pass@localhost:5432/mydb

# GitHub PAT with repo scope — used by fix agent to open PRs
UI_FIX_GITHUB_TOKEN=ghp_...

# Target repo for PRs (fix agent)
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=your-repo
GITHUB_BASE_BRANCH=main

# Set to "true" to skip real LLM call (returns hardcoded fail for pipeline testing)
MOCK_LLM=false
